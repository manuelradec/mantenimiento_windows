{
    "extends": ["web-recommended"],
    "hints": {
        "no-inline-styles": "off",
        "compat-api/css": ["default", {
            "ignore": ["user-select"]
        }],
        "axe/forms": "error",
        "axe/aria": "error",
        "axe/name-role-value": "error",
        "axe/keyboard": "error"
    }
}
