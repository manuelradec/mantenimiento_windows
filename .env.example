# CleanCPU environment configuration
# Copy this file to .env and adjust values for your deployment.
# None of these variables are required in local mode — the defaults work out of the box.

# ---------------------------------------------------------------------------
# Deployment environment
#   local       Default. Waitress binds 127.0.0.1. No proxy headers trusted.
#   staging     Behind Apache/nginx/ALB. Proxy headers trusted. HTTP cookies.
#   production  Behind HTTPS reverse proxy/ALB. Proxy headers trusted. Secure cookies.
# ---------------------------------------------------------------------------
CLEANCPU_ENV=local

# ---------------------------------------------------------------------------
# Network binding (Waitress / Flask)
#   127.0.0.1   Loopback only (default, safest for desktop use)
#   0.0.0.0     All interfaces (required behind AWS ALB / Docker)
# ---------------------------------------------------------------------------
CLEANCPU_HOST=127.0.0.1
CLEANCPU_PORT=5000

# ---------------------------------------------------------------------------
# Allowed Host headers (DNS-rebinding protection)
# Comma-separated list of hostnames/IPs that are accepted in the Host header.
# Wildcards supported: *.example.com
# These are ADDED to the built-in list (127.0.0.1, localhost, *.radec.com.mx, …).
# Leave blank if the built-in list is sufficient.
# ---------------------------------------------------------------------------
CLEANCPU_ALLOWED_HOSTS=

# Example (Apache/WampServer LAN deployment):
# CLEANCPU_ALLOWED_HOSTS=192.168.1.100,myserver.local

# Example (AWS with custom domain):
# CLEANCPU_ALLOWED_HOSTS=cleancpu.example.com,*.example.com

# ---------------------------------------------------------------------------
# Reverse-proxy trust
#   0 / false   Disabled (default for local)
#   1 / true    Trust X-Forwarded-For and X-Forwarded-Proto headers
#               (automatically enabled when CLEANCPU_ENV=staging or production)
# ---------------------------------------------------------------------------
CLEANCPU_TRUST_PROXY=false

# Number of trusted reverse-proxy hops (Apache/nginx = 1, double-proxy = 2)
CLEANCPU_PROXY_COUNT=1

# ---------------------------------------------------------------------------
# Flask secret key
# Used to sign session cookies. In production set this to a long random value
# and keep it secret. If unset, an ephemeral key is generated at startup
# (sessions reset on restart — fine for local desktop use).
# ---------------------------------------------------------------------------
# FLASK_SECRET_KEY=replace-with-a-long-random-string-in-production
